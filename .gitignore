# ==========================================================
# Vichy 2026 - .gitignore
# ==========================================================

# Dependencies (NEVER commit these)
node_modules/
.pnp
.pnp.js
package-lock.json
yarn.lock

# Next.js build output
.next/
out/

# Production builds
build/
dist/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables / credentials
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Python scripts con credenciales (preservado del original)
generar_crm.py
reporte_pdf.py
__pycache__/

# Bases de datos y reportes con datos personales (preservado del original)
*.xlsx
*.pdf

# OS files
.DS_Store
Thumbs.db
*.swp

# IDE files
.vscode/
.idea/
*.sublime-*

# Temp files
*.tmp
*.temp
~*
